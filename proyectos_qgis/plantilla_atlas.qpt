        <config>
         <Option type="Map">
          <Option name="IsMultiline" type="bool" value="false"/>
          <Option name="UseHtml" type="bool" value="false"/>
         </Option>
        </config>
       </editWidget>
      </field>
      <field configurationFlags="NoFlag" name="oficio_dic">
       <editWidget type="TextEdit">
        <config>
         <Option/>
        </config>
       </editWidget>
      </field>
      <field configurationFlags="NoFlag" name="fecha_oficio_dic">
       <editWidget type="DateTime">
        <config>
         <Option/>
        </config>
       </editWidget>
      </field>
