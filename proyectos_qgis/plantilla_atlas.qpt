     <defaults>
      <default expression="" applyOnUpdate="0" field="fid"/>
      <default expression="" applyOnUpdate="0" field="id"/>
      <default expression="" applyOnUpdate="0" field="nombre_general"/>
      <default expression="" applyOnUpdate="0" field="nombre"/>
      <default expression="" applyOnUpdate="0" field="tipo"/>
      <default expression="" applyOnUpdate="0" field="subtipo"/>
      <default expression="" applyOnUpdate="0" field="estatus_prosp"/>
      <default expression="" applyOnUpdate="0" field="fecha_prosp_inicial"/>
      <default expression="" applyOnUpdate="0" field="fecha_prosp_final"/>
      <default expression="" applyOnUpdate="0" field="arqlgo_prosp"/>
      <default expression="" applyOnUpdate="0" field="zona_utm"/>
      <default expression="" applyOnUpdate="0" field="poligono"/>
      <default expression="title( &quot;Localidad&quot; )" applyOnUpdate="1" field="localidad"/>
      <default expression="" applyOnUpdate="0" field="ubicacion"/>
      <default expression="round(AREA($GEOMETRY),3)" applyOnUpdate="1" field="area"/>
      <default expression="" applyOnUpdate="0" field="area_cons"/>
      <default expression="round(x(centroid($geometry)),3)" applyOnUpdate="1" field="x"/>
      <default expression="round(y(centroid($geometry)),3)" applyOnUpdate="1" field="y"/>
      <default expression="" applyOnUpdate="0" field="levantamiento"/>
      <default expression="" applyOnUpdate="0" field="minutado"/>
      <default expression="" applyOnUpdate="0" field="no_minuta_pros"/>
      <default expression="" applyOnUpdate="0" field="fecha_minuta"/>
      <default expression="" applyOnUpdate="0" field="tipo_dict_prosp"/>
      <default expression="&#xd;&#xa;-- Cuenta los monumentos de registrados en el campo de id de monumento&#xd;&#xa;&#xd;&#xa;length( &quot;id_monumento&quot; ) - length(replace( &quot;id_monumento&quot; , 'T', ''))" applyOnUpdate="1" field="no_monumentos"/>
      <default expression="--script para llenar el campo de id_monumento de la capa de obras &#xd;&#xa;--Reproyectar las capas a la zona correspondiente de la capa de obras&#xd;&#xa;--cambiar el nombre de las capas de monumetos lineas y mononumentos cedula a la zona utm correspondiente&#xd;&#xa;&#xd;&#xa;CASE  &#xd;&#xa;  WHEN array_length(array_distinct(array_cat(&#xd;&#xa;    overlay_intersects('monumentos_lineas', &quot;_name&quot;),&#xd;&#xa;    overlay_intersects('monumentos_cedula', &quot;ID Monumento&quot;)&#xd;&#xa;  ))) > 0 THEN array_to_string(&#xd;&#xa;    array_distinct(&#xd;&#xa;      array_cat(&#xd;&#xa;        overlay_intersects('monumentos_lineas', &quot;_name&quot;),&#xd;&#xa;        overlay_intersects('monumentos_cedula', &quot;ID Monumento&quot;)&#xd;&#xa;      )&#xd;&#xa;    ), ', '&#xd;&#xa;  )&#xd;&#xa;  ELSE 'No aplica'&#xd;&#xa;END" applyOnUpdate="1" field="id_monumento"/>
      <default expression="" applyOnUpdate="0" field="num_pol"/>
      <default expression="" applyOnUpdate="0" field="num_pol_m"/>
      <default expression="" applyOnUpdate="0" field="estatus_exc"/>
      <default expression="" applyOnUpdate="0" field="fecha_exc_inicial"/>
      <default expression="" applyOnUpdate="0" field="fecha_exc_final"/>
      <default expression="" applyOnUpdate="0" field="arqlgo_exc"/>
      <default expression="" applyOnUpdate="0" field="no_minuta_exc"/>
      <default expression="" applyOnUpdate="0" field="fecha_minuta_exc"/>
      <default expression="" applyOnUpdate="0" field="tipo_dict_ex"/>
      <default expression="case&#xd;&#xa; when&#xd;&#xa; &quot;Tipo_dict_prosp&quot; =1 and &quot;Tipo_dict_ex&quot; is NULL&#xd;&#xa; then 1&#xd;&#xa;when&#xd;&#xa; &quot;Tipo_dict_prosp&quot;=2 and &quot;Tipo_dict_ex&quot; is NULL&#xd;&#xa; then 2&#xd;&#xa;when&#xd;&#xa; &quot;Tipo_dict_prosp&quot;=3 and &quot;Tipo_dict_ex&quot; is NULL&#xd;&#xa; then 3&#xd;&#xa;when &#xd;&#xa; &quot;Tipo_dict_prosp&quot;=4 and &quot;Tipo_dict_ex&quot; is NULL&#xd;&#xa; then 4&#xd;&#xa;&#xd;&#xa; when&#xd;&#xa; &quot;Tipo_dict_ex&quot; =1 and  &quot;Tipo_dict_prosp&quot; is NULL&#xd;&#xa; then 5--los poligonos creados en etapa de excavacion&#xd;&#xa;&#xd;&#xa;when&#xd;&#xa; &quot;Tipo_dict_ex&quot; =1 and  &quot;Tipo_dict_prosp&quot;= 0&#xd;&#xa; then 5--los poligonos creados en etapa de excavacion&#xd;&#xa;&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot; =1 and &quot;Tipo_dict_prosp&quot;=2&#xd;&#xa;  then 5&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot; =1 and &quot;Tipo_dict_prosp&quot;=3&#xd;&#xa;  then 5&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot; =1 and &quot;Tipo_dict_prosp&quot;=4&#xd;&#xa;  then 5&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot; =1 and &quot;Tipo_dict_prosp&quot;=1&#xd;&#xa;  then 5&#xd;&#xa;&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=2 and &quot;Tipo_dict_prosp&quot; =1&#xd;&#xa;  then 2&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=2 and &quot;Tipo_dict_prosp&quot; =2&#xd;&#xa;  then 2&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=2 and &quot;Tipo_dict_prosp&quot; =3&#xd;&#xa;  then 2&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=2 and &quot;Tipo_dict_prosp&quot; =4&#xd;&#xa;  then 2&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=3 and &quot;Tipo_dict_prosp&quot; =1&#xd;&#xa;  then 3&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=3 and &quot;Tipo_dict_prosp&quot; =2&#xd;&#xa;  then 3&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=3 and &quot;Tipo_dict_prosp&quot; =3&#xd;&#xa;  then 3&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=3 and &quot;Tipo_dict_prosp&quot; =4&#xd;&#xa;  then 3&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=4 and &quot;Tipo_dict_prosp&quot; =1&#xd;&#xa;  then 4  &#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=4 and &quot;Tipo_dict_prosp&quot; =2&#xd;&#xa;  then 4&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=4 and &quot;Tipo_dict_prosp&quot; =3&#xd;&#xa;  then 4&#xd;&#xa;when&#xd;&#xa;  &quot;Tipo_dict_ex&quot;=4 and &quot;Tipo_dict_prosp&quot; =4&#xd;&#xa;  then 4&#xd;&#xa;when&#xd;&#xa;&#x9;&quot;Tipo_dict_prosp&quot; is NULL and &quot;Tipo_dict_ex&quot; is NULL&#xd;&#xa;&#x9;then 0 &#xd;&#xa;end" applyOnUpdate="1" field="dictamen"/>
      <default expression="" applyOnUpdate="0" field="pros_borrador"/>
      <default expression="" applyOnUpdate="0" field="min_prosp_firma"/>
      <default expression="" applyOnUpdate="0" field="exc_borrador"/>
      <default expression="" applyOnUpdate="0" field="min_exc_firma"/>
      <default expression="" applyOnUpdate="0" field="fecha_entrega_pros"/>
      <default expression="" applyOnUpdate="0" field="fecha_entrega_exc"/>
      <default expression="CASE&#xd;&#xa;WHEN&#xd;&#xa; &quot;Tipo_dict_prosp&quot; =1 THEN 'Visto bueno de obra'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_prosp&quot; =2 THEN 'Restricción provisional precautoria'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_prosp&quot; =3 THEN 'Restricción provisional precautoria, conservación de monumentos in situ'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_prosp&quot; =4 THEN 'Restricción total'&#xd;&#xa; END" applyOnUpdate="1" field="dict_prosp"/>
      <default expression="CASE&#xd;&#xa;WHEN&#xd;&#xa; &quot;Tipo_dict_ex&quot;  =1&#xd;&#xa; THEN &#xd;&#xa; 'Visto bueno de obra'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_ex&quot; =2&#xd;&#xa; THEN &#xd;&#xa; 'Restricción provisional precautoria'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_ex&quot; =3&#xd;&#xa; THEN &#xd;&#xa; 'Restricción provisional precautoria, conservación de monumentos in situ'&#xd;&#xa; WHEN&#xd;&#xa; &quot;Tipo_dict_ex&quot; =4&#xd;&#xa; THEN &#xd;&#xa; 'Restricción total'&#xd;&#xa; end" applyOnUpdate="1" field="dict_exc"/>
      <default expression="" applyOnUpdate="0" field="afectaciones"/>
      <default expression="" applyOnUpdate="0" field="observaciones"/>
      <default expression="" applyOnUpdate="0" field="fecha_actualización"/>
      <default expression="" applyOnUpdate="0" field="enlace"/>
      <default expression="" applyOnUpdate="0" field="no_oficio"/>
      <default expression="" applyOnUpdate="0" field="fecha_oficio"/>
      <default expression="" applyOnUpdate="0" field="vigencia"/>
      <default expression="" applyOnUpdate="0" field="fecha_recepcion"/>
      <default expression="" applyOnUpdate="0" field="fecha_integracion"/>
      <default expression="" applyOnUpdate="0" field="nombre_archivo"/>
      <default expression="" applyOnUpdate="0" field="formato"/>
      <default expression="" applyOnUpdate="0" field="receptor"/>
      <default expression="" applyOnUpdate="0" field="canal_recepcion"/>
      <default expression="" applyOnUpdate="0" field="procedencia"/>
      <default expression="" applyOnUpdate="0" field="remitente"/>
      <default expression="array_to_string(&#xd;&#xa;    array_filter(&#xd;&#xa;        array_cat(&#xd;&#xa;            -- datos de minutas pros&#xd;&#xa;            array(&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;CASE &#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_pros&quot; IS NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;THEN NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN length(&quot;no_minuta_pros&quot;) BETWEEN 20 AND 24&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;THEN NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_pros&quot; = 'No aplica'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;THEN NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;ELSE 'Verificar número de minuta'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;END&#xd;&#xa;            ),&#xd;&#xa;&#x9;&#x9;&#x9;--Revisa que haya una minuta cuando el campo de minutado es &quot;Si&quot; y que no haya cuando es &quot;No&quot;&#xd;&#xa;            array(&#xd;&#xa;                CASE &#xd;&#xa;                    WHEN &quot;minutado&quot; = 'Si' AND &quot;no_minuta_pros&quot; IS NULL AND &quot;no_minuta_exc&quot; IS NULL&#xd;&#xa;                    THEN ' Checar coherencia entre minutado y no_minuta' &#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;minutado&quot; = 'Si' AND &quot;no_minuta_pros&quot; IS NULL AND &quot;no_minuta_exc&quot; IS NOT NULL&#xd;&#xa;                    THEN NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;minutado&quot; = 'Si' AND &quot;no_minuta_pros&quot; IS NOT NULL AND &quot;no_minuta_exc&quot; IS NULL&#xd;&#xa;                    THEN NULL&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;minutado&quot; = 'No' AND &quot;no_minuta_pros&quot; IS NOT NULL &#xd;&#xa;                    THEN ' Checar coherencia entre minutado y no_minuta_pros' &#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;minutado&quot; = 'No' AND &quot;no_minuta_exc&quot; IS NOT NULL&#xd;&#xa;                    THEN ' Checar coherencia entre minutado y no_minuta_exc' &#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;minutado&quot; = 'Si' AND &quot;no_minuta_pros&quot; IS NOT NULL AND &quot;no_minuta_exc&quot; IS NOT NULL&#xd;&#xa;                    THEN NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;                END&#xd;&#xa;            ), &#xd;&#xa;            array(&#xd;&#xa;                CASE &#xd;&#xa;                   &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_pros&quot; IS NULL AND &quot;fecha_minuta&quot; IS NOT NULL&#xd;&#xa;                    THEN ' Revisar el no_minuta_pros'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_pros&quot; IS NOT NULL AND &quot;fecha_minuta&quot; IS NULL&#xd;&#xa;                    THEN ' Revisar fecha_minuta'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_exc&quot; IS NULL AND &quot;fecha_minuta_exc&quot; IS NOT NULL&#xd;&#xa;                    THEN ' Revisar el no_minuta_exc'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;WHEN &quot;no_minuta_exc&quot; IS NOT NULL AND &quot;fecha_minuta_exc&quot; IS NULL&#xd;&#xa;                    THEN ' Revisar fecha_minuta_exc'&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;ELSE NULL&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xd;&#xa;                END&#xd;&#xa;            ), &#xd;&#xa;            -- polígonos de restricción &#xd;&#xa;            array(&#xd;&#xa;                CASE&#xd;&#xa;                    WHEN &quot;subtipo&quot; = 'Polígono general' AND &quot;tipo_dict_prosp&quot; &lt;> '0'   &#xd;&#xa;                    THEN ' Verificar dictaminación del polígono general o subtipo'&#xd;&#xa;                    ELSE NULL &#xd;&#xa;                END&#xd;&#xa;            ), &#xd;&#xa;            array(&#xd;&#xa;                CASE &#xd;&#xa;                    WHEN &quot;tipo_dict_prosp&quot; = '1' AND &quot;id_monumento&quot; IS NULL &#xd;&#xa;                    THEN ' Actualizar id_monumento como &quot;No aplica&quot; '&#xd;&#xa;                    WHEN &quot;tipo_dict_prosp&quot; NOT IN ('2', '3', '4') AND &quot;id_monumento&quot; IS NULL&#xd;&#xa;                    THEN ' Falta actualizar id_monumento'&#xd;&#xa;                    ELSE NULL&#xd;&#xa;                END)&#xd;&#xa;            &#xd;&#xa;        ),  &#xd;&#xa;        @element IS NOT NULL&#xd;&#xa;    )&#xd;&#xa;)" applyOnUpdate="1" field="revision"/>
      <default expression="" applyOnUpdate="0" field="oficio_dic"/>
      <default expression="" applyOnUpdate="0" field="fecha_oficio_dic"/>
     </defaults>
     <constraints>
